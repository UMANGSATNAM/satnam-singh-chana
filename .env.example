# ============================================================
# Satnam Singh Chana — Environment Variables for Railway
# ============================================================
# Copy this to Railway Environment Variables and fill in the values
# ============================================================

# ─── DATABASE (Required) ────────────────────────────────────
# Railway will auto-provide this when you add PostgreSQL service
# Format: postgresql://user:password@host:port/database?schema=public
DATABASE_URL=

# ─── NEXTAUTH (Required) ────────────────────────────────────
NEXTAUTH_URL=https://your-app.up.railway.app
NEXTAUTH_SECRET=generate-a-random-secret-here

# ─── APP CONFIG ─────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── PAYMENT GATEWAYS (Optional — enable as needed) ─────────
# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Stripe
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PayU
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=

# ─── EMAIL / SMTP (Optional) ────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Satnam Singh Chana
SMTP_FROM_EMAIL=hello@satnamsinghchana.com

# ─── SMS (Optional) ─────────────────────────────────────────
SMS_PROVIDER=
SMS_API_KEY=

# ─── WHATSAPP (Optional) ────────────────────────────────────
WHATSAPP_PROVIDER=
WHATSAPP_API_KEY=
WHATSAPP_PHONE_ID=

# ─── ANALYTICS (Optional) ───────────────────────────────────
GA4_TRACKING_ID=
FB_PIXEL_ID=
GTM_ID=
